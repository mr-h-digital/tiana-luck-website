# =============================================================
#  Tiana Luck — Author Website  |  .gitignore
# =============================================================


# -------------------------------------------------------------
#  Claude / AI Tools
# -------------------------------------------------------------
.claude/
.claude-flow/
.cursorrules
.aider*
.copilot/


# -------------------------------------------------------------
#  OS — macOS
# -------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride


# -------------------------------------------------------------
#  OS — Windows
# -------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk


# -------------------------------------------------------------
#  OS — Linux
# -------------------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# -------------------------------------------------------------
#  Editors — VS Code
# -------------------------------------------------------------
.vscode/
!.vscode/extensions.json


# -------------------------------------------------------------
#  Editors — JetBrains (WebStorm, IntelliJ, etc.)
# -------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
out/


# -------------------------------------------------------------
#  Editors — Vim / Neovim
# -------------------------------------------------------------
*.swp
*.swo
*.swn
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist


# -------------------------------------------------------------
#  Editors — Sublime Text
# -------------------------------------------------------------
*.sublime-project
*.sublime-workspace


# -------------------------------------------------------------
#  Editors — Emacs
# -------------------------------------------------------------
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
auto-save-list
tramp
.\#*


# -------------------------------------------------------------
#  Node / npm (in case tooling is added later)
# -------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm
.yarn/
.pnp.*
.npmrc


# -------------------------------------------------------------
#  Build output (in case a build step is added later)
# -------------------------------------------------------------
dist/
build/
out/
.cache/
.parcel-cache/
.turbo/


# -------------------------------------------------------------
#  Environment & Secrets — never commit these
# -------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/


# -------------------------------------------------------------
#  Logs
# -------------------------------------------------------------
logs/
*.log
*.log.*


# -------------------------------------------------------------
#  Temporary & misc
# -------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
*.old
.temp/
.tmp/


# -------------------------------------------------------------
#  Static site deploy artefacts
# -------------------------------------------------------------
.netlify/
.vercel/
.firebase/
